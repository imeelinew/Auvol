<Window
    x:Class="Auvol.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Auvol — Audio Transport">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="32,28,32,32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="52" Height="52" CornerRadius="14"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xE767;" FontSize="25" Foreground="White" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="Auvol" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock Text="Low-latency audio over your local network"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Border Grid.Column="2" Padding="12,7" CornerRadius="16"
                        VerticalAlignment="Center"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse x:Name="StateDot" Width="8" Height="8"
                                 Fill="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="ConnectionStateText" Text="Idle"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Padding="20" CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="9">
                    <TextBlock Text="Peer device" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="IP address of the Mac on your local network"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBox x:Name="PeerIpTextBox"
                             PlaceholderText="192.168.101.162"
                             Header="IP address"
                             AutomationProperties.AutomationId="PeerIpAddress"
                             TextChanged="PeerIpTextBox_TextChanged" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Spacing="10">
                <TextBlock Text="Direction" FontSize="16" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ToggleButton x:Name="SendModeButton" Grid.Column="0"
                                  IsChecked="True" Click="DirectionButton_Click"
                                  HorizontalContentAlignment="Stretch"
                                  AutomationProperties.AutomationId="SendToMac">
                        <StackPanel Padding="8,7" Spacing="7">
                            <FontIcon Glyph="&#xE72A;" FontSize="20"
                                      HorizontalAlignment="Left" />
                            <TextBlock Text="Windows → Mac" FontWeight="SemiBold" />
                            <TextBlock Text="Capture this PC's default output"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ReceiveModeButton" Grid.Column="1"
                                  Click="DirectionButton_Click"
                                  HorizontalContentAlignment="Stretch"
                                  AutomationProperties.AutomationId="ReceiveFromMac">
                        <StackPanel Padding="8,7" Spacing="7">
                            <FontIcon Glyph="&#xE896;" FontSize="20"
                                      HorizontalAlignment="Left" />
                            <TextBlock Text="Mac → Windows" FontWeight="SemiBold" />
                            <TextBlock Text="Play through this PC's default output"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToggleButton>
                </Grid>
            </StackPanel>

            <Button x:Name="TransportButton" Grid.Row="3"
                    Height="46" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Style="{ThemeResource AccentButtonStyle}"
                    Content="Start transport"
                    Click="TransportButton_Click"
                    AutomationProperties.AutomationId="TransportToggle" />

            <InfoBar x:Name="TransportInfoBar" Grid.Row="4"
                     IsOpen="True" IsClosable="False"
                     Severity="Informational"
                     Title="Ready"
                     Message="Choose a direction, then start transport." />

            <StackPanel Grid.Row="5" Spacing="10">
                <TextBlock Text="Live transport" FontSize="16" FontWeight="SemiBold" />
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="14" CornerRadius="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="PACKETS" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PacketsValue" Text="0" FontSize="19" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="14" CornerRadius="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="SIGNAL · dBFS" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="SignalValue" Text="—" FontSize="19" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="14" CornerRadius="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="RateLabel" Text="CAPTURE · FRAMES/S" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="RateValue" Text="—" FontSize="19" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="14" CornerRadius="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="QUALITY" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="QualityValue" Text="—" FontSize="15"
                                       FontWeight="SemiBold" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock x:Name="RawStatsText" Text="No transport data yet"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           AutomationProperties.AutomationId="TransportStats" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
